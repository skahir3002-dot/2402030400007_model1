                <div class="result-card">
                    <h3 class="text-primary fw-bold mb-2" id="matchName">Loading Match...</h3>
                    <p class="mb-3 text-dark fw-medium" id="matchDetails"></p>
                    <h4 class="text-success fw-bold m-0" id="matchPrice"></h4>
                </div>

                <div class="mt-4 gap-3 d-flex justify-content-center">
