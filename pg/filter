    <!-- JAVASCRIPT FOR QUIZ LOGIC -->
    <script>
        // Questions and options configured in English
        const quizData = [
            {
                question: "1. Which locality in Ahmedabad do you prefer?",
                options: [
                    { text: "Satellite", value: "satellite" },
                    { text: "Navrangpura", value: "navrangpura" },
                    { text: "Bopal", value: "bopal" }
                ]
            },
            {
                question: "2. What is your monthly budget range?",
                options: [
                    { text: "₹5,000 - ₹7,000", value: "budget" },
                    { text: "₹7,000 - ₹10,000", value: "medium" },
                    { text: "Above ₹10,000 (Premium Luxury)", value: "premium" }
                ]
            },
            {
                question: "3. What type of room sharing are you looking for?",
                options: [
                    { text: "Single Private Room", value: "single" },
                    { text: "Double / Triple Sharing Room", value: "sharing" }
                ]
            },
            {
                question: "4. Do you require food services (Mess facilities)?",
                options: [
                    { text: "Yes, food services included", value: "with-food" },
                    { text: "No, food services not required", value: "no-food" }
                ]
            }
        ];

        let currentQuestionIndex = 0;
        let userAnswers = [];

        const questionText = document.getElementById("questionText");
        const optionsContainer = document.getElementById("optionsContainer");
        const prevBtn = document.getElementById("prevBtn");
        const nextBtn = document.getElementById("nextBtn");
        const quizProgress = document.getElementById("quizProgress");
        const quizScreen = document.getElementById("quizScreen");
        const resultScreen = document.getElementById("resultScreen");

        function loadQuestion() {
            // Update progress bar
            let progressPercent = ((currentQuestionIndex + 1) / quizData.length) * 100;
            quizProgress.style.width = progressPercent + "%";

            // Setup current question text
            let currentQuestion = quizData[currentQuestionIndex];
            questionText.innerText = currentQuestion.question;

            // Clear old values and append updated options
            optionsContainer.innerHTML = "";
            currentQuestion.options.forEach((option, index) => {
                let isChecked = userAnswers[currentQuestionIndex] === option.value ? "checked" : "";
                let isSelectedClass = userAnswers[currentQuestionIndex] === option.value ? "selected" : "";

                let optionHtml = `
                    <div class="quiz-option ${isSelectedClass}" onclick="selectOption(this, '${option.value}')">
                        <input type="radio" name="optionRadio" id="opt_${index}" value="${option.value}" ${isChecked}>
                        <label class="m-0" style="cursor:pointer; width: 100%;" for="opt_${index}">${option.text}</label>
                    </div>
                `;
                optionsContainer.innerHTML += optionHtml;
            });

            // Conditionally control back button visibility
            if (currentQuestionIndex === 0) {
                prevBtn.style.display = "none";
            } else {
                prevBtn.style.display = "block";
            }

            // Alter next button label for submission step
            if (currentQuestionIndex === quizData.length - 1) {
                nextBtn.innerText = "Submit";
            } else {
                nextBtn.innerText = "Next";
            }
        }

        function selectOption(element, value) {
            document.querySelectorAll('.quiz-option').forEach(el => el.classList.remove('selected'));
            element.classList.add('selected');
            element.querySelector('input').checked = true;
            
            userAnswers[currentQuestionIndex] = value;
        }

        nextBtn.addEventListener("click", function() {
            // Validation script: Ensure option is checked before proceeding
            if (!userAnswers[currentQuestionIndex]) {
                alert("Please select an option before moving forward!");
                return;
            }

            if (currentQuestionIndex < quizData.length - 1) {
                currentQuestionIndex++;
                loadQuestion();
            } else {
                showResults();
            }
        });

        prevBtn.addEventListener("click", function() {
            if (currentQuestionIndex > 0) {
                currentQuestionIndex--;
                loadQuestion();
            }
        });

        function showResults() {
            quizScreen.style.display = "none";
            resultScreen.style.display = "block";
            quizProgress.parentElement.style.display = "none";

            let location = userAnswers[0];
            let budget = userAnswers[1];

            // Default output card fallback values
            let pgName = "Comfort Stay PG";
            let pgPrice = "₹6,500/month";
            let pgDetails = "Located in Satellite. Fully equipped with modern Air Conditioning, High-speed Wi-Fi network systems, and 3 fresh meals daily.";

            if (location === "navrangpura") {
                pgName = "Elite Living PG";
                pgPrice = "₹5,500/month";
                pgDetails = "Located in Navrangpura. Dedicated separate wings for Boys and Girls, silent library study zones, and walking distance to the Metro Station.";
            } else if (budget === "premium") {
                pgName = "Skyline Luxury Studio";
                pgPrice = "₹12,000/month";
                pgDetails = "Located in Bopal. Premium individual independent suites equipped with customized fitness gym access and daily professional housekeeping service.";
            }

            document.getElementById("matchName").innerText = pgName;
            document.getElementById("matchDetails").innerText = pgDetails;
            document.getElementById("matchPrice").innerText = pgPrice;
        }

        function restartQuiz() {
            currentQuestionIndex = 0;
            userAnswers = [];
            quizScreen.style.display = "block";
            resultScreen.style.display = "none";
            quizProgress.parentElement.style.display = "flex";
            loadQuestion();
        }

        // Initialize quiz instance execution
        loadQuestion();
    </script>
</body>

