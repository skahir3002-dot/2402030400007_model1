<style>

body{
    margin:0;
    font-family:Arial,sans-serif;
    background:#eef4ff;
}

/* NAVBAR */
.custom-nav{
    background:rgba(255,255,255,0.95);
    backdrop-filter:blur(10px);
    box-shadow:0 4px 20px rgba(0,0,0,0.08);
}

.navbar-brand{
    font-size:32px;
    font-weight:bold;
}

.nav-link{
    color:#111 !important;
    font-weight:600;
}

.nav-link:hover{
    color:#0d6efd !important;
}

/* HERO */
.hero{
    background:linear-gradient(135deg,#0d6efd,#00c6ff);
    color:white;
    text-align:center;
    padding:80px 20px;
    border-radius:0 0 40px 40px;
    position:relative;
    overflow:hidden;
}

/* floating circles */
.circle{
    position:absolute;
    border-radius:50%;
    background:rgba(255,255,255,0.2);
    animation: float 6s infinite ease-in-out;
}

/* FIXED POSITIONS */
.c1{
    width:140px;
    height:140px;
    top:10px;
    left:6%;
}

.c2{
    width:90px;
    height:90px;
    bottom:15px;
    right:8%;
}

@keyframes float{
    0%,100%{transform:translateY(0);}
    50%{transform:translateY(-20px);}
}

.hero h1{
    font-size:55px;
    font-weight:bold;
    letter-spacing:1px;
}

/* ✅ FIX: CONTACT WRAPPER POSITION */
.contact-wrapper{
    margin-top:20px;   /* ❗ fixed (was negative before) */
}

/* CONTACT CARD */
.contact-card{ 
    background:white; 
    border-radius:25px; 
    padding:35px; 
    box-shadow:0 10px 30px rgba(0,0,0,0.08); 
    transition:0.3s;
    height:100%; 
    text-align:center; 
} 

.contact-card:hover{ 
    transform:translateY(-8px); 
} 

/* ICON */ 
.icon{ 
    width:80px; 
    height:80px;
    background:linear-gradient(135deg,#0d6efd,#00c6ff);
    color:white; 
    font-size:35px;
    border-radius:50%; 
    display:flex; 
    align-items:center;
    justify-content:center; 
    margin:auto; 
    margin-bottom:20px;
}

/* TEXT */ 
.contact-card h4{ 
    font-weight:bold;
    margin-bottom:15px;
}

.contact-card p{ 
    color:#666;
    margin:0;
    font-size:17px;
}

/* FOOTER */
footer{
    background:#111827;
    color:#ccc;
    margin-top:80px;
    padding:50px 0;
}

.footer-link{
    display:block;
    color:#aaa;
    text-decoration:none;
    margin:6px 0;
}

.footer-link:hover{
    color:white;
}

</style>
</head>

