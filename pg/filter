    <style>
        body { margin: 0; font-family: 'Poppins', Arial, sans-serif; background: #f4f7ff; }
        .custom-nav { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08); }
        .nav-link { color: #111 !important; font-weight: 600; }
        .nav-link:hover { color: #0d6efd !important; }
        
        /* QUIZ CONTAINER */
        .quiz-container { max-width: 650px; margin: 60px auto; background: white; border-radius: 25px; padding: 40px; box-shadow: 0 15px 35px rgba(0, 0, 0, 0.06); position: relative; overflow: hidden; border: 1px solid rgba(13, 110, 253, 0.1); }
        .progress { height: 10px; border-radius: 10px; margin-bottom: 35px; background-color: #eef2f7; }
        .progress-bar { background: linear-gradient(135deg, #0d6efd, #00c6ff); transition: width 0.4s ease; }
        
        .question-title { font-weight: 800; color: #111827; margin-bottom: 25px; font-size: 24px; letter-spacing: -0.5px; }
        
        /* OPTION BOXES */
        .quiz-option { border: 2px solid #e2e8f0; border-radius: 16px; padding: 18px; margin-bottom: 15px; cursor: pointer; transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1); display: flex; align-items: center; gap: 15px; background: #fff; }
        .quiz-option:hover { border-color: #0d6efd; background: #f8fafc; transform: translateY(-2px); box-shadow: 0 4px 12px rgba(13, 110, 253, 0.05); }
        .quiz-option.selected { border-color: #0d6efd; background: linear-gradient(90deg, #f0f7ff, #e6f2ff); font-weight: 600; box-shadow: 0 4px 12px rgba(13, 110, 253, 0.1); }
        .quiz-option input[type="radio"] { width: 22px; height: 22px; cursor: pointer; accent-color: #0d6efd; }
        
        /* BUTTONS */
        .quiz-btn { border: none; padding: 14px 35px; border-radius: 14px; font-weight: bold; font-size: 16px; transition: all 0.3s ease; }
        .btn-next { background: linear-gradient(135deg, #0d6efd, #00c6ff); color: white; box-shadow: 0 4px 15px rgba(13, 110, 253, 0.2); }
        .btn-next:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(13, 110, 253, 0.3); }
        .btn-prev { background: #e2e8f0; color: #475569; }
        .btn-prev:hover { background: #cbd5e1; color: #1e293b; }
        
        /* RESULT CARD */
        .result-card { background: linear-gradient(135deg, #f0f7ff, #ffffff); border: 2px dashed #0d6efd; border-radius: 20px; padding: 30px; text-align: center; margin-top: 25px; box-shadow: 0 10px 25px rgba(13, 110, 253, 0.05); }

        footer { background: #111827; color: #ccc; margin-top: 80px; padding: 50px 0; }
        .footer-link { display: block; color: #aaa; text-decoration: none; margin: 5px 0; transition: color 0.2s; }
        .footer-link:hover { color: white; }
    </style>
</head>

